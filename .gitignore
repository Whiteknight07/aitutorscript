.env
.env.local
.env*.local

# Local datasets and scratch space
tmp/
.venv/
data/*
!data/README.md
!data/publication/
!data/publication/**

# OS files
.DS_Store
Thumbs.db

# Editor directories
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
